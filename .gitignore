.DS_Store

# Python cache
__pycache__/
*.pyc
*.pyo

# Local credentials and session state
/live_dashboard/live_dashboard.env
/recordings/live_dashboard.env
/video_pipeline/auth/sftraders.json

# Runtime service data
/live_dashboard/live_service_data/
/recordings/watch_runtime/

# Browser profiles are local machine state, not source
/video_pipeline/browser_profile/*
!/video_pipeline/browser_profile/README.md

# Common local logs and pid files
*.log
*.pid

# Large binaries — not source code
recordings/.bin/
recordings/pion_gst_direct_chain/pion_gst_direct_chain
recordings/mac_app/MatchPlanRecorderApp/dist/

# LoRA adapter weights (large, reproducible from training script)
analysis_vlm/training/adapters/*/*.safetensors

# Benchmark report data (reproducible)
analysis_vlm/reports/*/

# Video pipeline removed — ignore stale paths
/video_pipeline/
