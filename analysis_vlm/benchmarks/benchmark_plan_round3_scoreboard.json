{
  "version": 1,
  "phase": "phase_1_online_baseline_round_3_scoreboard_ocr",
  "goal": "通过只看顶部记分牌/时间区域的裁剪图，验证比分与比赛时间读取能力是否优于整图或普通多帧输入。",
  "allowed_material_sources": [
    "/Volumes/990 PRO PCIe 4T/match_plan_dataset_library/01_gold_matches",
    "/Volumes/990 PRO PCIe 4T/match_plan_dataset_library/04_golden_samples"
  ],
  "input_strategy": {
    "type": "scoreboard_top_strip_contact_sheet",
    "frame_count": 3,
    "frame_positions": [0.15, 0.5, 0.85],
    "crop_region": {
      "left_ratio": 0.0,
      "top_ratio": 0.0,
      "width_ratio": 1.0,
      "height_ratio": 0.22
    },
    "prompt_mode": "ocr_strict_json"
  },
  "candidate_models_round_3": [
    "Qwen3.5-VL-9B-8bit-MLX-CRACK",
    "Qwen3.5-VL-35B-A3B-4bit-MLX-CRACK"
  ],
  "tasks": [
    {
      "id": "scoreboard_ocr_score",
      "description": "读取画面顶部的比分牌并输出 score_detected。"
    },
    {
      "id": "scoreboard_ocr_clock",
      "description": "读取画面顶部的比赛时间并输出 match_clock_detected。"
    }
  ],
  "metrics": [
    "json_valid_rate",
    "score_exact_match_rate",
    "clock_exact_match_rate",
    "clock_minute_match_rate",
    "avg_latency_ms"
  ]
}
